{% extends 'chat/index.html.twig' %}

{% block title %}Chats{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
<link rel="stylesheet" href="{{ asset('assets_chat/vendor/OverlayScrollbars-master/css/OverlayScrollbars.min.css') }}">
<link rel="preconnect" href="https://fonts.googleapis.com/">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap">
<link rel="stylesheet" type="text/css" href="{{ asset('assets_chat/css/style.css') }}">
<style>
.chat-link {
    cursor: pointer;
    transition: background-color 0.2s;
}
.chat-link:hover {
    background-color: #f8f9fa;
}
.chat-link.active {
    background-color: #e9ecef;
}
</style>


<!-- Container START -->
<div class="container">
    <div class="row gx-0">
        <!-- Sidebar START -->
        <div class="col-lg-4 col-xxl-3" id="chatTabs" role="tablist">
            <!-- Divider -->
            <div class="d-flex align-items-center mb-4 d-lg-none">
                <button class="border-0 bg-transparent" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar" aria-controls="offcanvasNavbar">
                    <span class="btn btn-primary"><i class="fa-solid fa-sliders-h"></i></span>
                    <span class="h6 mb-0 fw-bold d-lg-none ms-2">Chats</span>
                </button>
            </div>
            <!-- Advanced filter responsive toggler END -->
            <div class="card card-body border-end-0 border-bottom-0 rounded-bottom-0">
                <div class=" d-flex justify-content-between align-items-center">
                    <h1 class="h5 mb-0">Active chats <span class="badge bg-success bg-opacity-10 text-success">{{ conversations|length }}</span></h1>
                    <!-- Chat new create message item START -->
                    <div class="dropend position-relative">
                        <div class="nav">
                            <a class="icon-md rounded-circle btn btn-sm btn-primary-soft nav-link toast-btn" data-target="chatToast" href="#" > <i class="bi bi-pencil-square"></i> </a>
                        </div>
                    </div>
                    <!-- Chat new create message item END -->
                </div>
            </div>

            <nav class="navbar navbar-light navbar-expand-lg mx-0">
                <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasNavbar">
                    <!-- Offcanvas header -->
                    <div class="offcanvas-header">
                        <button type="button" class="btn-close text-reset ms-auto" data-bs-dismiss="offcanvas"></button>
                    </div>

                    <!-- Offcanvas body -->
                    <div class="offcanvas-body p-0">
                        <div class="card card-chat-list rounded-end-lg-0 card-body border-end-lg-0 rounded-top-0">
                            <!-- Search chat START -->
                            <form class="position-relative">
                                <input class="form-control py-2" type="search" placeholder="Search for chats" aria-label="Search">
                                <button class="btn bg-transparent text-secondary px-2 py-0 position-absolute top-50 end-0 translate-middle-y" type="submit">
                                    <i class="bi bi-search fs-5"></i>
                                </button>
                            </form>
                            <!-- Search chat END -->
                            <!-- Chat list tab START -->
                            <div class="mt-4 h-100">
                                <div class="chat-tab-list custom-scrollbar">
                                    <ul class="nav flex-column nav-pills nav-pills-soft">
                                        {% for chatss in conversations %}
                                        <li data-bs-dismiss="offcanvas">
                                            <!-- Chat user tab item -->
                                            <a href="#" class="nav-link text-start chat-link{% if current_chat is defined and current_chat.id == chatss.id %} active{% endif %}" data-chat-id="{{ chatss.id }}" onclick="loadChat({{ chatss.id }})">
                                                <div class="d-flex">
                                                    <div class="flex-shrink-0 avatar{% if not chatss.isRead %} avatar-story{% endif %} me-2{% if chatss.isRead %} status-online{% else %} status-offline{% endif %}">
                                                        <img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/placeholder.jpg') }}" alt="">
                                                    </div>
                                                    <div class="flex-grow-1 d-block">
                                                        <h6 class="mb-0 mt-1">Chat #{{ chatss.id }}</h6>
                                                        <div class="small text-secondary">{{ chatss.dernierMessage ?: 'No messages yet' }}</div>
                                                    </div>
                                                </div>
                                            </a>
                                        </li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            </div>
                            <!-- Chat list tab END -->
                        </div>
                    </div>
                </div>
            </nav>
        </div>
        <!-- Sidebar START -->

        <!-- Main content for chat list -->
        <div class="col-lg-8 col-xxl-9">
            <div class="card card-chat rounded-start-lg-0 border-start-lg-0">
                <div class="card-body h-100">
                    <div class="d-flex align-items-center justify-content-end">
                        <!-- Call button -->
                        <a href="#!" class="icon-md rounded-circle btn btn-primary-soft me-2 px-2" data-bs-toggle="tooltip" data-bs-placement="top" title="Audio call"><i class="bi bi-telephone-fill"></i></a>
                        <a href="#!" class="icon-md rounded-circle btn btn-primary-soft me-2 px-2" data-bs-toggle="tooltip" data-bs-placement="top" title="Video call"><i class="bi bi-camera-video-fill"></i></a>
                        <!-- Card action START -->
                        <div class="dropdown">
                          <a class="icon-md rounded-circle btn btn-primary-soft me-2 px-2" href="#" id="chatcoversationDropdown" role="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false"><i class="bi bi-three-dots-vertical"></i></a>
                          <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="chatcoversationDropdown">
                            <li><button class="dropdown-item chat-action" data-action="mark-read" data-chat-id="1"><i class="bi bi-check-lg me-2 fw-icon"></i>Mark as read</button></li>
                            <li><button class="dropdown-item chat-action" data-action="mute" data-chat-id="1"><i class="bi bi-mic-mute me-2 fw-icon"></i>Mute conversation</button></li>
                            <li><button class="dropdown-item chat-action" data-action="delete" data-chat-id="1"><i class="bi bi-trash me-2 fw-icon"></i>Delete chat</button></li>
                            <li class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-archive me-2 fw-icon"></i>Archive chat</a></li>
                          </ul>
                        </div>
                    </div>
                    <hr>
                    <!-- Chat conversation START -->
                    <div class="chat-conversation-content custom-scrollbar" id="chat-messages">
                        <!-- Messages will be loaded dynamically here -->
                    </div>
                    <!-- Chat conversation END -->
                </div>
                <div class="card-footer">
                    <div class="d-sm-flex align-items-end">
                        <textarea class="form-control mb-sm-0 mb-3" placeholder="Type a message" rows="1" spellcheck="false"></textarea>
                        <input type="file" id="file-upload" style="display: none;" />
                        <button id="emojiBtn" class="btn btn-sm btn-danger-soft ms-sm-2"><i class="fa-solid fa-face-laugh-beam fs-6"></i></button>
                        <button class="btn btn-sm btn-secondary-soft ms-2" onclick="document.getElementById('file-upload').click();"><i class="fa-solid fa-upload fs-6"></i></button>
                        <button class="btn btn-sm btn-primary ms-2"><i class="fa-solid fa-paper-plane fs-6"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Container END -->
{% block javascripts %}
<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<!-- OverlayScrollbars v1 (compatible theme) -->
<script src="https://cdn.jsdelivr.net/npm/overlayscrollbars@1.13.1/js/OverlayScrollbars.min.js"></script>
<!-- Theme Functions -->
<script src="{{ asset('assets/js/function_chat.js') }}"></script>
<!-- Chat JS -->
<script src="{{ asset('assets/js/chat.js') }}"></script>

<div id="chat-data" data-chat-id="{{ current_chat is defined ? current_chat.id : (conversations|length > 0 ? conversations[0].id : 1) }}" data-user-id="{{ current_user_id is defined ? current_user_id : 1 }}" style="display: none;"></div>

{% endblock %}


{% endblock %}
