{% extends 'base_backoffice.html.twig' %}

{% block title %}Modifier l'Événement{% endblock %}

{% block body %}
<div class="dashboard-content-one">

    <!-- Edit Event Area Start Here -->
    <div class="card height-auto">
        <div class="card-body">
            <div class="heading-layout1 mb-4">
                <div class="item-title">
                    <h3><i class="fas fa-edit text-warning me-2"></i> Modifier l'Événement</h3>
                </div>
                <div class="dropdown">
                    <span class="badge bg-secondary px-3 py-2">
                        <i class="fas fa-info-circle me-1"></i> {{ evenement.titre }}
                    </span>
                </div>
            </div>
            
            {{ form_start(form, {'attr': {'class': 'new-added-form', 'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
                <div class="row">
                    <!-- Titre -->
                    <div class="col-12 form-group mb-4">
                        <label class="form-label fw-bold">
                            <i class="fas fa-heading text-primary me-1"></i> Titre de l'événement <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.titre, {'attr': {'class': 'form-control form-control-lg'}}) }}
                        {% if form.titre.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.titre.vars.errors %}
                                    <i class="fas fa-exclamation-triangle me-1"></i> {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    
                    <!-- Description -->
                    <div class="col-12 form-group mb-4">
                        <label class="form-label fw-bold">
                            <i class="fas fa-align-left text-primary me-1"></i> Description <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
                        {% if form.description.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.description.vars.errors %}
                                    <i class="fas fa-exclamation-triangle me-1"></i> {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    
                    <!-- Date et Horaires -->
                    <div class="col-xl-4 col-lg-4 col-12 form-group mb-4">
                        <label class="form-label fw-bold">
                            <i class="fas fa-calendar-alt text-primary me-1"></i> Date <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.dateEvenement, {'attr': {'class': 'form-control'}}) }}
                        {% if form.dateEvenement.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.dateEvenement.vars.errors %}
                                    <i class="fas fa-exclamation-triangle me-1"></i> {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    
                    <div class="col-xl-4 col-lg-4 col-12 form-group mb-4">
                        <label class="form-label fw-bold">
                            <i class="fas fa-clock text-success me-1"></i> Heure début <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.heureDebut, {'attr': {'class': 'form-control'}}) }}
                        {% if form.heureDebut.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.heureDebut.vars.errors %}
                                    <i class="fas fa-exclamation-triangle me-1"></i> {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    
                    <div class="col-xl-4 col-lg-4 col-12 form-group mb-4">
                        <label class="form-label fw-bold">
                            <i class="fas fa-clock text-danger me-1"></i> Heure fin <span class="text-danger">*</span>
                        </label>
                        {{ form_widget(form.heureFin, {'attr': {'class': 'form-control'}}) }}
                        {% if form.heureFin.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.heureFin.vars.errors %}
                                    <i class="fas fa-exclamation-triangle me-1"></i> {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                    
                    <div class="col-xl-6 col-lg-6 col-12 form-group mb-4">
                        <label class="form-label fw-bold">
                            <i class="fas fa-tag text-primary me-1"></i> Type d'événement
                        </label>
                        {{ form_widget(form.typeEvenement, {'attr': {'class': 'form-select'}}) }}
                    </div>
                    
                    <!-- Image -->
                    <div class="col-xl-6 col-lg-6 col-12 form-group mb-4">
                        <label class="form-label fw-bold">
                            <i class="fas fa-image text-primary me-1"></i> Image de l'événement
                            {% if not evenement.image %}<span class="text-danger">*</span>{% endif %}
                        </label>
                        
                        {% if evenement.image %}
                        <div class="mb-3 p-3 bg-success bg-opacity-10 rounded border border-success">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-check-circle text-success me-2"></i>
                                <strong class="text-success">Image actuelle :</strong>
                            </div>
                            <img src="{{ asset('uploads/' ~ evenement.image) }}" alt="{{ evenement.titre }}" class="img-thumbnail" style="max-height: 120px;">
                        </div>
                        <label class="form-label small text-muted">Changer l'image (facultatif) :</label>
                        {% else %}
                        <div class="mb-3 p-3 bg-warning bg-opacity-10 rounded border border-warning">
                            <i class="fas fa-exclamation-triangle text-warning me-2"></i>
                            <span class="text-warning"><strong>Aucune image</strong></span>
                        </div>
                        {% endif %}
                        
                        {{ form_widget(form.imageUpload, {'attr': {'class': 'form-control', 'id': 'imageUpload', 'onchange': 'previewImage(this)'}}) }}
                        {% if form.imageUpload.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.imageUpload.vars.errors %}
                                    <i class="fas fa-exclamation-triangle me-1"></i> {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                        <small class="form-text text-muted d-block mt-2">
                            <i class="fas fa-info-circle me-1"></i> Formats acceptés: JPEG, PNG, GIF, WebP (max 5 Mo)
                        </small>
                        <div class="mt-2">
                            <button type="button" class="btn btn-sm btn-outline-info" id="recommendImageBtn" onclick="recommendImage()">
                                <i class="fas fa-magic me-1"></i> Recommander une image avec l'IA
                            </button>
                            <div id="imageRecommendation" class="mt-3" style="display: none;">
                                <div class="alert alert-success border">
                                    <strong><i class="fas fa-image me-1"></i> Image recommandée :</strong>
                                    <div class="mt-3 text-center">
                                        <img id="recommendedImage" src="" alt="Image recommandée" class="img-fluid rounded shadow-sm" style="max-height: 300px; cursor: pointer;" onclick="useRecommendedImage(this.src)">
                                        <div class="mt-2">
                                            <button type="button" class="btn btn-sm btn-success" onclick="useRecommendedImage(document.getElementById('recommendedImage').src)">
                                                <i class="fas fa-check me-1"></i> Utiliser cette image
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="imagePreview" class="mt-3 p-3 bg-info bg-opacity-10 rounded border border-info" style="display: none;">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-eye text-info me-2"></i>
                                <strong class="text-info">Nouvelle image :</strong>
                            </div>
                            <img id="previewImg" src="" alt="Aperçu" class="img-thumbnail" style="max-height: 120px;">
                        </div>
                    </div>
                    
                    <!-- Localisation -->
                    <div class="col-xl-6 col-lg-6 col-12 form-group mb-4">
                        <label class="form-label fw-bold">
                            <i class="fas fa-map-marker-alt text-primary me-1"></i> Localisation
                        </label>
                        {{ form_widget(form.localisation, {'attr': {'class': 'form-control'}}) }}
                    </div>
                    
                    <!-- Nombre de places disponibles -->
                    <div class="col-md-6 form-group mb-4">
                        <label class="form-label fw-bold">
                            <i class="fas fa-users text-primary me-1"></i> Nombre de places disponibles
                        </label>
                        {{ form_widget(form.nbPlacesDisponibles, {'attr': {'class': 'form-control'}}) }}
                        {% if form.nbPlacesDisponibles.vars.errors|length > 0 %}
                            <div class="invalid-feedback d-block">
                                {% for error in form.nbPlacesDisponibles.vars.errors %}
                                    <i class="fas fa-exclamation-triangle me-1"></i> {{ error.message }}
                                {% endfor %}
                            </div>
                        {% endif %}
                        <small class="form-text text-muted">
                            <i class="fas fa-info-circle me-1"></i> Laissez vide si le nombre de places est illimité. 
                            {% if evenement.nbPlacesDisponibles is not null %}
                                <br><strong>Places réservées : {{ evenement.nbPlacesReservees }} / {{ evenement.nbPlacesDisponibles }}</strong>
                            {% endif %}
                        </small>
                        <small class="form-text text-muted">Adresse ou lieu de l'événement (optionnel)</small>
                    </div>
                    
                    <!-- Info sur le programme -->
                    <div class="col-12 form-group mb-4">
                        {% if evenement.programme %}
                        <div class="alert alert-success mb-0">
                            <i class="fas fa-check-circle me-2"></i>
                            <strong>Programme associé :</strong> Cet événement possède un programme.
                            <a href="{{ path('app_programme_show', {'id': evenement.programme.id}) }}" class="float-end text-success">
                                <i class="fas fa-external-link-alt"></i> Voir le programme
                            </a>
                        </div>
                        {% else %}
                        <div class="alert alert-warning mb-0">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            <strong>Aucun programme associé</strong> - Cet événement n'a pas encore de programme.
                            <a href="{{ path('app_programme_new') }}" class="float-end text-warning">
                                <i class="fas fa-plus-circle"></i> Créer un programme
                            </a>
                        </div>
                        {% endif %}
                    </div>
                    
                    <!-- Buttons -->
                    <div class="col-12 form-group mt-4">
                        <hr class="mb-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <button type="submit" class="btn btn-outline-success px-4 py-2">
                                <i class="fas fa-save me-1"></i> Enregistrer les modifications
                            </button>
                            <a href="{{ path('app_evenement_index') }}" class="btn btn-outline-primary px-4 py-2">
                                <i class="fas fa-arrow-left me-1"></i> Retour à la liste
                            </a>
                        </div>
                    </div>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
    <!-- Edit Event Area End Here -->
</div>

<script>
function previewImage(input) {
    var preview = document.getElementById('imagePreview');
    var previewImg = document.getElementById('previewImg');
    
    if (input.files && input.files[0]) {
        var reader = new FileReader();
        reader.onload = function(e) {
            previewImg.src = e.target.result;
            preview.style.display = 'block';
        }
        reader.readAsDataURL(input.files[0]);
    } else {
        preview.style.display = 'none';
    }
}

function recommendImage() {
    const titre = document.querySelector('input[name="evenement[titre]"]').value;
    const description = document.querySelector('textarea[name="evenement[description]"]').value;
    const btn = document.getElementById('recommendImageBtn');
    const recommendationDiv = document.getElementById('imageRecommendation');
    
    if (!titre && !description) {
        alert('Veuillez remplir au moins le titre ou la description de l\'événement.');
        return;
    }
    
    // Désactiver le bouton et afficher le chargement
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Génération en cours...';
    recommendationDiv.style.display = 'none';
    
    // Appel AJAX
    fetch('{{ path("app_evenement_recommend_image") }}', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            titre: titre,
            description: description
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Afficher l'image recommandée
            const recommendedImage = document.getElementById('recommendedImage');
            if (data.imageUrl) {
                recommendedImage.src = data.imageUrl;
                recommendedImage.style.display = 'block';
            } else {
                recommendedImage.style.display = 'none';
            }
            
            // Afficher la recommandation
            recommendationDiv.style.display = 'block';
        } else {
            alert('Erreur: ' + (data.message || 'Une erreur est survenue'));
        }
    })
    .catch(error => {
        console.error('Erreur:', error);
        alert('Une erreur est survenue lors de la génération des recommandations.');
    })
    .finally(() => {
        // Réactiver le bouton
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-magic me-1"></i> Recommander une image avec l\'IA';
    });
}

function useRecommendedImage(imageUrl) {
    if (!imageUrl) {
        alert('Aucune image à télécharger.');
        return;
    }

    // Télécharger l'image depuis l'URL
    fetch(imageUrl)
        .then(response => response.blob())
        .then(blob => {
            // Créer un fichier à partir du blob
            const file = new File([blob], 'recommended-image.jpg', { type: 'image/jpeg' });
            
            // Créer un DataTransfer pour ajouter le fichier au champ input
            const dataTransfer = new DataTransfer();
            dataTransfer.items.add(file);
            
            // Trouver le champ input file
            const fileInput = document.querySelector('input[type="file"][name*="imageUpload"]');
            if (fileInput) {
                fileInput.files = dataTransfer.files;
                
                // Déclencher l'événement change pour afficher la prévisualisation
                const event = new Event('change', { bubbles: true });
                fileInput.dispatchEvent(event);
                
                // Afficher un message de succès
                alert('Image recommandée ajoutée avec succès !');
            }
        })
        .catch(error => {
            console.error('Erreur lors du téléchargement de l\'image:', error);
            alert('Erreur lors du téléchargement de l\'image. Veuillez réessayer.');
        });
}
</script>
{% endblock %}
