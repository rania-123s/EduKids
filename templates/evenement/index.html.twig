{% extends 'base_backoffice.html.twig' %}

{% block title %}Liste des Événements{% endblock %}

{% block body %}
<div class="dashboard-content-one">

    <!-- Flash Messages - Notification stylée -->
    {% for message in app.flashes('success') %}
        <div id="successModal" class="notification-overlay">
            <div class="notification-modal">
                <div class="notification-icon">
                    <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
                        <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none"/>
                        <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
                    </svg>
                </div>
                <h4 class="notification-title">{{ message }}</h4>
                <button type="button" class="btn btn-success mt-3 px-4" onclick="closeNotification()">OK</button>
            </div>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}
    
    <style>
    .notification-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        animation: fadeIn 0.3s ease;
    }
    
    .notification-modal {
        background: white;
        padding: 40px 60px;
        border-radius: 15px;
        text-align: center;
        box-shadow: 0 10px 50px rgba(0, 0, 0, 0.3);
        animation: slideIn 0.4s ease;
    }
    
    .notification-icon {
        margin-bottom: 20px;
    }
    
    .notification-title {
        color: #333;
        font-weight: 500;
        margin: 0;
    }
    
    /* Checkmark animation */
    .checkmark {
        width: 80px;
        height: 80px;
    }
    
    .checkmark-circle {
        stroke: #4CAF50;
        stroke-width: 2;
        stroke-dasharray: 166;
        stroke-dashoffset: 166;
        animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
    }
    
    .checkmark-check {
        stroke: #4CAF50;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-dasharray: 48;
        stroke-dashoffset: 48;
        animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.6s forwards;
    }
    
    @keyframes stroke {
        100% { stroke-dashoffset: 0; }
    }
    
    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    
    @keyframes slideIn {
        from { transform: translateY(-50px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
    
    @keyframes fadeOut {
        from { opacity: 1; }
        to { opacity: 0; }
    }
    </style>

    <!-- Table Area Start Here -->
    <div class="card height-auto">
        <div class="card-body">
            <div class="heading-layout1 mb-4 d-flex justify-content-between align-items-center">
                <div class="item-title">
                    <h3><i class="fas fa-calendar-alt text-primary me-2"></i> Tous les Événements</h3>
                </div>
                <div>
                    <a href="{{ path('app_evenement_new') }}" class="btn-fill-lg bg-blue-dark btn-hover-yellow">
                        <i class="fas fa-plus-circle me-1"></i> Nouvel Événement
                    </a>
                </div>
            </div>
            
            <!-- Zone de recherche dynamique -->
            <div class="mb-4">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="fas fa-search text-primary"></i>
                    </span>
                    <input type="text" 
                           id="searchEvenement" 
                           class="form-control border-start-0 ps-0" 
                           placeholder="Rechercher un événement par nom..."
                           onkeyup="filterEvenements()">
                    <button class="btn btn-outline-secondary" type="button" onclick="clearSearch()">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <small class="text-muted mt-1 d-block">
                    <i class="fas fa-info-circle me-1"></i> La recherche démarre automatiquement dès que vous tapez
                </small>
            </div>
            
            <div class="table-responsive">
                <table class="table table-hover table-striped">
                    <thead class="bg-light">
                        <tr>
                            <th style="width: 80px;"><i class="fas fa-image me-1"></i> Image</th>
                            <th><i class="fas fa-heading me-1"></i> Titre</th>
                            <th><i class="fas fa-align-left me-1"></i> Description</th>
                            <th class="text-center"><i class="fas fa-calendar me-1"></i> Date</th>
                            <th class="text-center"><i class="fas fa-clock me-1"></i> Horaires</th>
                            <th class="text-center"><i class="fas fa-clipboard-list me-1"></i> Programme</th>
                            <th class="text-center" style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for evenement in evenements %}
                        <tr class="evenement-row" data-titre="{{ evenement.titre|lower }}">
                            <td>
                                {% if evenement.image %}
                                    <img src="{{ asset('uploads/' ~ evenement.image) }}" alt="{{ evenement.titre }}" class="rounded" style="width: 60px; height: 40px; object-fit: cover;">
                                {% else %}
                                    <img src="{{ asset('assets/images/event/01.jpg') }}" alt="Default" class="rounded" style="width: 60px; height: 40px; object-fit: cover;">
                                {% endif %}
                            </td>
                            <td>
                                <strong class="text-dark">{{ evenement.titre }}</strong>
                            </td>
                            <td>
                                <span class="text-muted">{{ evenement.description|slice(0, 80) }}{% if evenement.description|length > 80 %}...{% endif %}</span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-primary rounded-pill px-3 py-2">
                                    <i class="fas fa-calendar-day me-1"></i>
                                    {{ evenement.dateEvenement ? evenement.dateEvenement|date('d/m/Y') : '-' }}
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-success px-2 py-1">{{ evenement.heureDebut ? evenement.heureDebut|date('H:i') : '-' }}</span>
                                <span class="text-muted">-</span>
                                <span class="badge bg-danger px-2 py-1">{{ evenement.heureFin ? evenement.heureFin|date('H:i') : '-' }}</span>
                                <div><small class="text-muted">{{ evenement.dureeFormatee }}</small></div>
                            </td>
                            <td class="text-center">
                                {% if evenement.programme %}
                                    <span class="badge bg-success px-3 py-2" title="Programme défini">
                                        <i class="fas fa-check me-1"></i> Défini
                                    </span>
                                {% else %}
                                    <span class="badge bg-warning text-dark px-3 py-2" title="Aucun programme">
                                        <i class="fas fa-exclamation me-1"></i> Non défini
                                    </span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <a href="{{ path('app_evenement_show', {'id': evenement.id}) }}" 
                                       class="btn btn-sm btn-outline-info" title="Voir les détails">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('app_evenement_edit', {'id': evenement.id}) }}" 
                                       class="btn btn-sm btn-outline-warning" title="Modifier">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" action="{{ path('app_evenement_delete', {'id': evenement.id}) }}" 
                                          style="display: inline-block;" 
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer l\'événement « {{ evenement.titre }} » ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ evenement.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="empty-state">
                                    <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                                    <h5 class="text-muted">Aucun événement trouvé</h5>
                                    <p class="text-muted mb-3">Commencez par créer votre premier événement</p>
                                    <a href="{{ path('app_evenement_new') }}" class="btn btn-primary">
                                        <i class="fas fa-plus-circle me-1"></i> Créer un événement
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            
            {% if evenements|length > 0 %}
            <div class="mt-3">
                <small id="searchResultCount" class="text-muted"><i class="fas fa-info-circle me-1"></i> Total : {{ evenements|length }} événement(s)</small>
            </div>
            {% endif %}
        </div>
    </div>
    <!-- Table Area End Here -->
</div>

<script>
function closeNotification() {
    const modal = document.getElementById('successModal');
    if (modal) {
        modal.style.animation = 'fadeOut 0.3s ease';
        setTimeout(() => {
            modal.remove();
        }, 300);
    }
}

// Auto-close notification after 3 seconds
setTimeout(() => {
    closeNotification();
}, 3000);

function filterEvenements() {
    const searchValue = document.getElementById('searchEvenement').value.toLowerCase();
    const rows = document.querySelectorAll('.evenement-row');
    let visibleCount = 0;
    
    rows.forEach(function(row) {
        const titre = row.getAttribute('data-titre');
        if (titre.includes(searchValue)) {
            row.style.display = '';
            visibleCount++;
        } else {
            row.style.display = 'none';
        }
    });
    
    // Mettre à jour le compteur
    const totalInfo = document.getElementById('searchResultCount');
    if (totalInfo) {
        if (searchValue.length > 0) {
            totalInfo.innerHTML = '<i class="fas fa-filter me-1"></i> ' + visibleCount + ' événement(s) trouvé(s)';
            totalInfo.classList.remove('text-muted');
            totalInfo.classList.add('text-primary');
        } else {
            totalInfo.innerHTML = '<i class="fas fa-info-circle me-1"></i> Total : {{ evenements|length }} événement(s)';
            totalInfo.classList.remove('text-primary');
            totalInfo.classList.add('text-muted');
        }
    }
}

function clearSearch() {
    document.getElementById('searchEvenement').value = '';
    filterEvenements();
    document.getElementById('searchEvenement').focus();
}
</script>
{% endblock %}
