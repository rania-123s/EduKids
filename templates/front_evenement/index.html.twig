<!-- FullCalendar CDN -->
<link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css' rel='stylesheet' />
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js'></script>

<script>
// ========== CALENDRIER ==========
let calendar = null;

// Données des événements pour le calendrier
const eventsData = [
	{% for evenement in evenements %}
	{
		id: {{ evenement.id }},
		title: "{{ evenement.titre|e('js') }}",
		start: "{{ evenement.dateEvenement ? evenement.dateEvenement|date('Y-m-d') : '' }}{{ evenement.heureDebut ? 'T' ~ evenement.heureDebut|date('H:i:s') : '' }}",
		end: "{{ evenement.dateEvenement ? evenement.dateEvenement|date('Y-m-d') : '' }}{{ evenement.heureFin ? 'T' ~ evenement.heureFin|date('H:i:s') : '' }}",
		url: "{{ path('app_front_evenement_show', {'id': evenement.id}) }}",
		extendedProps: {
			description: "{{ evenement.description|slice(0, 100)|e('js') }}...",
			likes: {{ evenement.likesCount }},
			heureDebut: "{{ evenement.heureDebut ? evenement.heureDebut|date('H:i') : '-' }}",
			heureFin: "{{ evenement.heureFin ? evenement.heureFin|date('H:i') : '-' }}",
			image: "{% if evenement.image %}{{ asset('uploads/' ~ evenement.image) }}{% else %}{{ asset('assets/images/event/01.jpg') }}{% endif %}"
		}
	}{% if not loop.last %},{% endif %}
	{% endfor %}
];

function initCalendar() {
	const calendarEl = document.getElementById('calendar');
	const today = new Date().toISOString().split('T')[0];
	
	// Ajouter des classes selon la date
	const eventsWithClasses = eventsData.map(event => {
		let className = 'fc-event-future';
		if (event.start < today) {
			className = 'fc-event-past';
		} else if (event.start === today) {
			className = 'fc-event-today';
		}
		return { ...event, className };
	});
	
	calendar = new FullCalendar.Calendar(calendarEl, {
		initialView: 'dayGridMonth',
		locale: 'fr',
		headerToolbar: {
			left: 'prev,next today',
			center: 'title',
			right: 'dayGridMonth,timeGridWeek,listWeek'
		},
		buttonText: {
			today: "Aujourd'hui",
			month: 'Mois',
			week: 'Semaine',
			list: 'Liste'
		},
		events: eventsWithClasses,
		eventClick: function(info) {
			info.jsEvent.preventDefault();
			if (info.event.url) {
				window.location.href = info.event.url;
			}
		},
		eventDidMount: function(info) {
			// Tooltip au survol avec les horaires
			const heureDebut = info.event.extendedProps.heureDebut || '';
			const heureFin = info.event.extendedProps.heureFin || '';
			const horaires = heureDebut && heureFin ? ' (' + heureDebut + ' - ' + heureFin + ')' : '';
			info.el.setAttribute('title', info.event.title + horaires + ' - Cliquez pour voir les détails');
		},
		displayEventTime: true,
		eventTimeFormat: {
			hour: '2-digit',
			minute: '2-digit',
			hour12: false
		},
		height: 'auto',
		aspectRatio: 1.8
	});
}

function switchView(view) {
	const listView = document.getElementById('events-grid');
	const calendarView = document.getElementById('calendar-section');
	const searchSection = document.getElementById('search-section');
	const sortSection = document.getElementById('sort-section');
	const btnList = document.getElementById('btn-list-view');
	const btnCalendar = document.getElementById('btn-calendar-view');
	
	if (view === 'list') {
		listView.style.display = 'flex';
		calendarView.style.display = 'none';
		searchSection.style.display = 'block';
		sortSection.style.display = 'block';
		btnList.classList.add('active');
		btnCalendar.classList.remove('active');
	} else {
		listView.style.display = 'none';
		calendarView.style.display = 'block';
		searchSection.style.display = 'none';
		sortSection.style.display = 'none';
		btnList.classList.remove('active');
		btnCalendar.classList.add('active');
		
		// Initialiser le calendrier si pas encore fait
		if (!calendar) {
			initCalendar();
		}
		calendar.render();
	}
}

// Fonction de recherche des événements (côté client, sans rechargement)
function searchEvents(query) {
	const cards = document.querySelectorAll('.event-card');
	const searchTerm = query.toLowerCase().trim();
	let visibleCount = 0;
	
	cards.forEach(card => {
		const title = card.dataset.title || '';
		const description = card.querySelector('.card-text')?.textContent.toLowerCase() || '';
		
		if (searchTerm === '' || title.includes(searchTerm) || description.includes(searchTerm)) {
			card.style.display = '';
			visibleCount++;
		} else {
			card.style.display = 'none';
		}
	});
	
	// Afficher un message si aucun résultat
	let noResultMsg = document.getElementById('no-results-message');
	if (visibleCount === 0 && searchTerm !== '') {
		if (!noResultMsg) {
			noResultMsg = document.createElement('div');
			noResultMsg.id = 'no-results-message';
			noResultMsg.className = 'col-12';
			noResultMsg.innerHTML = `
				<div class="no-results-card">
					<div class="no-results-icon">
						<i class="bi bi-search"></i>
					</div>
					<h4>Aucun événement trouvé</h4>
					<p>Aucun résultat pour "<strong class="search-term">${searchTerm}</strong>"</p>
					<button class="btn btn-outline-primary btn-sm" onclick="clearSearch()">
						<i class="bi bi-arrow-counterclockwise me-1"></i>Effacer la recherche
					</button>
				</div>
			`;
			document.getElementById('events-grid').appendChild(noResultMsg);
		} else {
			noResultMsg.querySelector('.search-term').textContent = searchTerm;
			noResultMsg.style.display = '';
		}
	} else if (noResultMsg) {
		noResultMsg.style.display = 'none';
	}
}

function clearSearch() {
	const searchInput = document.getElementById('search-input');
	searchInput.value = '';
	searchEvents('');
	searchInput.focus();
}

// Fonction de tri des événements (côté client, sans rechargement)
function sortEvents(sortType) {
	const grid = document.getElementById('events-grid');
	const cards = Array.from(grid.querySelectorAll('.event-card'));
	
	// Mettre à jour les boutons actifs
	document.querySelectorAll('.sort-btn').forEach(btn => {
		btn.classList.remove('btn-primary', 'btn-success', 'btn-secondary');
		btn.classList.add('btn-outline-primary', 'btn-outline-success', 'btn-outline-secondary');
		
		if (btn.dataset.sort === sortType) {
			btn.classList.remove('btn-outline-primary', 'btn-outline-success', 'btn-outline-secondary');
			if (sortType === 'likes') {
				btn.classList.add('btn-success');
			} else if (sortType.startsWith('title')) {
				btn.classList.add('btn-secondary');
			} else {
				btn.classList.add('btn-primary');
			}
		}
	});
	
	// Trier les cartes
	cards.sort((a, b) => {
		switch(sortType) {
			case 'date_desc':
				return b.dataset.date.localeCompare(a.dataset.date);
			case 'date_asc':
				return a.dataset.date.localeCompare(b.dataset.date);
			case 'likes':
				return parseInt(b.dataset.likes) - parseInt(a.dataset.likes);
			case 'title_asc':
				return a.dataset.title.localeCompare(b.dataset.title);
			case 'title_desc':
				return b.dataset.title.localeCompare(a.dataset.title);
			default:
				return 0;
		}
	});
	
	// Réorganiser les cartes dans le DOM
	cards.forEach(card => grid.appendChild(card));
}

function reactToEvent(eventId, type, e) {
	// Empêcher la propagation vers le lien stretched-link
	e.preventDefault();
	e.stopPropagation();
	
	const url = `/interaction/${type}/${eventId}`;
	
	fetch(url, {
		method: 'POST',
		headers: {
			'Content-Type': 'application/json',
			'X-Requested-With': 'XMLHttpRequest'
		}
	})
	.then(response => response.json())
	.then(data => {
		if (data.success) {
			// Mettre à jour les compteurs
			document.querySelector('.likes-count-' + eventId).textContent = data.likes;
			document.querySelector('.dislikes-count-' + eventId).textContent = data.dislikes;
			
			// Mettre à jour les styles des boutons
			const likeBtn = document.querySelector('.like-btn-' + eventId);
			const dislikeBtn = document.querySelector('.dislike-btn-' + eventId);
			
			// Reset des boutons
			likeBtn.classList.remove('active-like');
			dislikeBtn.classList.remove('active-dislike');
			
			// Appliquer le nouveau style
			if (data.userReaction === 'like') {
				likeBtn.classList.add('active-like');
			} else if (data.userReaction === 'dislike') {
				dislikeBtn.classList.add('active-dislike');
			}
		}
	})
	.catch(error => {
		console.error('Erreur:', error);
	});
}

function toggleFavorite(eventId, e) {
	// Empêcher la propagation vers le lien stretched-link
	e.preventDefault();
	e.stopPropagation();
	
	const url = `/interaction/favorite/${eventId}`;
	
	fetch(url, {
		method: 'POST',
		headers: {
			'Content-Type': 'application/json',
			'X-Requested-With': 'XMLHttpRequest'
		}
	})
	.then(response => response.json())
	.then(data => {
		if (data.success) {
			// Mettre à jour le style du bouton
			const favoriteBtn = document.querySelector('.favorite-btn-' + eventId);
			const heartIcon = favoriteBtn.querySelector('i');
			
			if (data.isFavorite) {
				favoriteBtn.classList.add('active-favorite');
				// Changer l'icône en cœur plein
				heartIcon.classList.remove('far');
				heartIcon.classList.add('fas');
			} else {
				favoriteBtn.classList.remove('active-favorite');
				// Changer l'icône en cœur vide
				heartIcon.classList.remove('fas');
				heartIcon.classList.add('far');
			}
			
			// Mettre à jour le badge des favoris dans la navbar
			updateFavoritesBadge(data.totalUserFavorites);
		}
	})
	.catch(error => {
		console.error('Erreur:', error);
	});
}

// Fonction pour mettre à jour le badge des favoris
function updateFavoritesBadge(count) {
	const navFavIcon = document.querySelector('.nav-favorites-icon');
	if (!navFavIcon) return;
	
	let badge = navFavIcon.querySelector('.favorites-badge');
	
	if (count > 0) {
		const displayCount = count > 99 ? '99+' : count;
		if (badge) {
			badge.textContent = displayCount;
		} else {
			badge = document.createElement('span');
			badge.className = 'favorites-badge';
			badge.textContent = displayCount;
			navFavIcon.appendChild(badge);
		}
	} else {
		if (badge) {
			badge.remove();
		}
	}
}
</script>

<!-- Script pour charger le modal de réservation -->
<script>
function loadReservationModal(evenementId) {
	// Vérifier si le modal existe déjà
	let modalElement = document.getElementById('reservationModal' + evenementId);
	
	if (modalElement) {
		// Le modal existe déjà, juste l'afficher
		const modal = new bootstrap.Modal(modalElement);
		modal.show();
		return;
	}
	
	// Charger le formulaire via AJAX
	fetch('/reservation/participer/' + evenementId, {
		method: 'GET',
		headers: {
			'X-Requested-With': 'XMLHttpRequest'
		}
	})
	.then(response => response.text())
	.then(html => {
		// Créer un conteneur temporaire pour parser le HTML
		const tempDiv = document.createElement('div');
		tempDiv.innerHTML = html;
		
		// Extraire le modal du HTML
		const modalHtml = tempDiv.querySelector('.modal');
		if (modalHtml) {
			// Ajouter le modal au body
			document.body.appendChild(modalHtml);
			
			// Afficher le modal
			const modal = new bootstrap.Modal(modalHtml);
			modal.show();
			
			// Nettoyer après fermeture
			modalHtml.addEventListener('hidden.bs.modal', function() {
				modalHtml.remove();
			});
		}
	})
	.catch(error => {
		console.error('Erreur lors du chargement du formulaire:', error);
		alert('Une erreur est survenue lors du chargement du formulaire.');
	});
}
</script>
