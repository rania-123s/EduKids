{% extends 'base_frontoffice.html.twig' %}

{% block title %}{{ evenement.titre }}{% endblock %}

{% block body %}
<!-- =======================
Page Banner START -->
<section class="py-4 py-lg-5 bg-light">
	<div class="container">
		<div class="row">
			<div class="col-12">
				<div class="d-flex justify-content-between align-items-center flex-wrap">
					<div>
						<h1 class="mb-2">{{ evenement.titre }}</h1>
						{% if evenement.typeEvenement %}
						<span class="badge bg-secondary px-3 py-2">
							<i class="fas fa-tag me-1"></i>
							{{ evenement.typeEvenementLabel }}
						</span>
						{% endif %}
					</div>
					<div class="mt-3 mt-md-0">
						<span class="badge bg-primary px-3 py-2 fs-6">
							<i class="bi bi-calendar3 me-2"></i>
							{{ evenement.dateEvenement ? evenement.dateEvenement|date('d/m/Y') : 'Date à définir' }}
						</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
<!-- =======================
Page Banner END -->

<!-- =======================
Event Detail START -->
<section class="pt-0 pt-lg-5">
	<div class="container">
		<div class="row g-4 g-lg-5">
			
			<!-- Main content START -->
			<div class="col-lg-8">
				<div class="card shadow">
					<!-- Featured image -->
					<div class="rounded-top overflow-hidden">
						{% if evenement.image %}
							<img src="{{ asset('uploads/' ~ evenement.image) }}" class="card-img-top" alt="{{ evenement.titre }}" style="height: 300px; object-fit: cover;">
						{% else %}
							<img src="{{ asset('assets/images/event/01.jpg') }}" class="card-img-top" alt="{{ evenement.titre }}" style="height: 300px; object-fit: cover;">
						{% endif %}
					</div>
					
					<!-- Card body -->
					<div class="card-body p-4">
						<!-- Title -->
						<h2 class="mb-3">
							<i class="bi bi-calendar-event text-primary me-2"></i>
							{{ evenement.titre }}
						</h2>
						
						<!-- Meta info -->
						<div class="d-flex flex-wrap gap-2 mb-4">
							<span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">
								<i class="fas fa-calendar me-2"></i>
								{{ evenement.dateEvenement ? evenement.dateEvenement|date('d/m/Y') : 'Date à définir' }}
							</span>
							<span class="badge bg-success bg-opacity-10 text-success px-3 py-2">
								<i class="fas fa-clock me-2"></i>
								{{ evenement.heureDebut ? evenement.heureDebut|date('H:i') : '-' }} - {{ evenement.heureFin ? evenement.heureFin|date('H:i') : '-' }}
								<span class="ms-1">({{ evenement.dureeFormatee }})</span>
							</span>
							{% if evenement.nbPlacesDisponibles is not null %}
							<span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2">
								<i class="fas fa-users me-2"></i>
								Places restantes : <strong>{{ evenement.nbPlacesRestantes }}</strong> / {{ evenement.nbPlacesDisponibles }}
							</span>
							{% else %}
							<span class="badge bg-info bg-opacity-10 text-info px-3 py-2">
								<i class="fas fa-users me-2"></i>
								Places illimitées
							</span>
							{% endif %}
							{% if evenement.programme %}
							<span class="badge bg-info bg-opacity-10 text-info px-3 py-2">
								<i class="fas fa-clipboard-check me-2"></i>
								Programme disponible
							</span>
							{% endif %}
						</div>
						
						<!-- Description -->
						<div class="bg-light p-4 rounded-3 mb-4">
							<h5 class="mb-3"><i class="bi bi-text-paragraph me-2 text-primary"></i>Description de l'événement</h5>
							<p class="mb-0">{{ evenement.description|nl2br }}</p>
						</div>
						
						<!-- Localisation et Carte Google Maps -->
						{% if evenement.localisation %}
						<div class="mb-4">
							<h5 class="mb-3"><i class="bi bi-geo-alt-fill me-2 text-danger"></i>Localisation</h5>
							<div class="card border">
								<div class="card-body">
									<div class="d-flex justify-content-between align-items-center mb-3">
										<p class="mb-0">
											<i class="bi bi-pin-map me-2 text-primary"></i>
											<strong>{{ evenement.localisation }}</strong>
										</p>
										<a href="https://www.google.com/maps/search/?api=1&query={{ evenement.localisation|url_encode }}" 
										   target="_blank" 
										   class="btn btn-sm btn-primary">
											<i class="bi bi-box-arrow-up-right me-1"></i>Ouvrir dans Google Maps
										</a>
									</div>
									<!-- Google Maps Iframe -->
									<div class="ratio ratio-16x9" style="border-radius: 10px; overflow: hidden;">
										<iframe 
											src="https://www.google.com/maps?q={{ evenement.localisation|url_encode }}&output=embed"
											style="border:0; border-radius: 10px;" 
											allowfullscreen="" 
											loading="lazy" 
											referrerpolicy="no-referrer-when-downgrade">
										</iframe>
									</div>
								</div>
							</div>
						</div>
						{% endif %}
						
						<!-- Section Programme -->
						{% if evenement.programme %}
						<hr class="my-4">
						<h4 class="mb-4">
							<i class="fas fa-clipboard-list me-2 text-warning"></i>
							Programme de l'événement 
						</h4>
						
						<div class="row g-4">
							<!-- Pause -->
							<div class="col-12">
								<div class="card border-warning">
									<div class="card-header bg-warning text-dark py-2">
										<i class="fas fa-coffee me-2"></i> <strong>Horaires de Pause</strong>
									</div>
									<div class="card-body">
										<div class="row text-center">
											<div class="col-4">
												<h5 class="text-success mb-1">{{ evenement.programme.pauseDebut|date('H:i') }}</h5>
												<small class="text-muted">Début</small>
											</div>
											<div class="col-4">
												<h5 class="text-dark mb-1">{{ evenement.programme.dureePause }} min</h5>
												<small class="text-muted">Durée</small>
											</div>
											<div class="col-4">
												<h5 class="text-danger mb-1">{{ evenement.programme.pauseFin|date('H:i') }}</h5>
												<small class="text-muted">Fin</small>
											</div>
										</div>
									</div>
								</div>
							</div>
							
							<!-- Activités -->
							<div class="col-12">
								<div class="card border-success h-100">
									<div class="card-header bg-success text-white py-2">
										<i class="fas fa-running me-2"></i> <strong>Activités Prévues</strong>
									</div>
									<div class="card-body">
										<p class="mb-0" style="white-space: pre-line;">{{ evenement.programme.activites }}</p>
									</div>
								</div>
							</div>
							
							<!-- Documents -->
							<div class="col-md-6">
								<div class="card border-info h-100">
									<div class="card-header bg-info text-white py-2">
										<i class="fas fa-file-alt me-2"></i> <strong>Documents Requis</strong>
									</div>
									<div class="card-body">
										<p class="mb-0" style="white-space: pre-line;">{{ evenement.programme.documentsRequis }}</p>
									</div>
								</div>
							</div>
							
							<!-- Matériel -->
							<div class="col-md-6">
								<div class="card border-secondary h-100">
									<div class="card-header bg-secondary text-white py-2">
										<i class="fas fa-tools me-2"></i> <strong>Matériels Requis</strong>
									</div>
									<div class="card-body">
										<p class="mb-0" style="white-space: pre-line;">{{ evenement.programme.materielsRequis }}</p>
									</div>
								</div>
							</div>
						</div>
						{% else %}
						<div class="alert alert-info">
							<i class="bi bi-info-circle me-2"></i>
							Le programme de cet événement sera bientôt disponible.
						</div>
						{% endif %}
					</div>
				</div>
			</div>
			<!-- Main content END -->
			
			<!-- Sidebar START -->
			<div class="col-lg-4">
				<!-- Event info card -->
				<div class="card shadow mb-4">
					<div class="card-header bg-primary">
						<h5 class="card-title text-white mb-0">
							<i class="fas fa-info-circle me-2"></i>Informations
						</h5>
					</div>
					<div class="card-body">
						<ul class="list-group list-group-flush">
							<li class="list-group-item d-flex justify-content-between align-items-center px-0">
								<span><i class="fas fa-calendar text-primary me-2"></i>Date</span>
								<span class="fw-bold">{{ evenement.dateEvenement ? evenement.dateEvenement|date('d/m/Y') : 'N/A' }}</span>
							</li>
							<li class="list-group-item d-flex justify-content-between align-items-center px-0">
								<span><i class="fas fa-clock text-success me-2"></i>Horaires</span>
								<span>
									<span class="badge bg-success">{{ evenement.heureDebut ? evenement.heureDebut|date('H:i') : '-' }}</span>
									-
									<span class="badge bg-danger">{{ evenement.heureFin ? evenement.heureFin|date('H:i') : '-' }}</span>
								</span>
							</li>
							<li class="list-group-item d-flex justify-content-between align-items-center px-0">
								<span><i class="fas fa-hourglass-half text-warning me-2"></i>Durée</span>
								<span class="badge bg-warning text-dark">{{ evenement.dureeFormatee }}</span>
							</li>
							{% if evenement.typeEvenement %}
							<li class="list-group-item d-flex justify-content-between align-items-center px-0">
								<span><i class="fas fa-tag text-secondary me-2"></i>Type</span>
								<span class="badge bg-secondary">{{ evenement.typeEvenementLabel }}</span>
							</li>
							{% endif %}
							<li class="list-group-item d-flex justify-content-between align-items-center px-0">
								<span><i class="fas fa-clipboard-list text-info me-2"></i>Programme</span>
								{% if evenement.programme %}
									<span class="badge bg-success"><i class="fas fa-check"></i> Disponible</span>
								{% else %}
									<span class="badge bg-warning text-dark">À venir</span>
								{% endif %}
							</li>
							{% if evenement.localisation %}
							<li class="list-group-item px-0">
								<span><i class="fas fa-map-marker-alt text-danger me-2"></i>Lieu</span>
								<p class="mb-0 mt-1 small text-muted">{{ evenement.localisation }}</p>
							</li>
							{% endif %}
						</ul>
					</div>
				</div>
				
				<!-- Résumé du programme -->
				{% if evenement.programme %}
				<div class="card shadow mb-4">
					<div class="card-header bg-light">
						<h5 class="card-title mb-0">
							<i class="fas fa-clipboard-check me-2 text-primary"></i>Résumé du Programme
						</h5>
					</div>
					<div class="card-body">
						<div class="d-flex justify-content-between align-items-center mb-2">
							<span class="badge bg-warning text-dark">
								<i class="fas fa-coffee me-1"></i>Pause
							</span>
							<span class="small">{{ evenement.programme.pauseDebut|date('H:i') }} - {{ evenement.programme.pauseFin|date('H:i') }}</span>
						</div>
						
						<div class="d-flex justify-content-between align-items-center mb-2">
							<span class="badge bg-success">
								<i class="fas fa-running me-1"></i>Activités
							</span>
							<i class="fas fa-check-circle text-success"></i>
						</div>
						
						<div class="d-flex justify-content-between align-items-center mb-2">
							<span class="badge bg-info">
								<i class="fas fa-file-alt me-1"></i>Documents
							</span>
							<i class="fas fa-check-circle text-success"></i>
						</div>
						
						<div class="d-flex justify-content-between align-items-center">
							<span class="badge bg-secondary">
								<i class="fas fa-tools me-1"></i>Matériels
							</span>
							<i class="fas fa-check-circle text-success"></i>
						</div>
					</div>
				</div>
				{% endif %}
				
				<!-- Back button -->
				<div class="d-grid">
					<a href="{{ path('app_front_evenement_index') }}" class="btn btn-primary">
						<i class="fas fa-arrow-left me-2"></i>Retour aux événements
					</a>
				</div>
			</div>
			<!-- Sidebar END -->
			
		</div>
	</div>
</section>
<!-- =======================
Event Detail END -->

{% endblock %}
