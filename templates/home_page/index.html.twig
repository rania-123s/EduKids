{% extends 'base_frontoffice.html.twig' %}

{% block body %}
<style>
		.home-page {
			--ep-primary: #066ac9;
			--ep-primary-deep: #0557a8;
			--ep-warning: #f7c32e;
			--ep-warning-soft: #fff3d2;
			--ep-ink: #1f2f46;
			--ep-surface: #ffffff;
			--ep-line: #e6edf7;
			background:
				radial-gradient(circle at 10% -10%, rgba(6, 106, 201, 0.08) 0%, rgba(6, 106, 201, 0) 42%),
				radial-gradient(circle at 92% 0%, rgba(247, 195, 46, 0.2) 0%, rgba(247, 195, 46, 0) 30%),
				#f8fbff;
			color: var(--ep-ink);
		}

		.home-page .home-hero-section {
			position: relative;
			overflow: hidden;
			padding-bottom: 2rem;
		}

		.home-page .home-hero-section::before {
			content: "";
			position: absolute;
			top: -140px;
			right: -120px;
			width: 340px;
			height: 340px;
			border-radius: 50%;
			background: radial-gradient(circle, rgba(6, 106, 201, 0.18) 0%, rgba(6, 106, 201, 0) 70%);
			pointer-events: none;
		}

		.home-page .home-hero-card {
			position: relative;
			overflow: hidden;
			border: 0;
			border-radius: 1.25rem !important;
			background:
				linear-gradient(130deg, rgba(19, 55, 97, 0.96) 0%, rgba(8, 104, 181, 0.9) 58%, rgba(11, 131, 165, 0.88) 100%),
				url('{{ asset('assets/images/pattern/05.png') }}') center center / cover no-repeat;
			box-shadow: 0 1.6rem 3.4rem rgba(10, 39, 74, 0.34);
		}

		.home-page .home-hero-card::after {
			content: "";
			position: absolute;
			inset: auto -80px -100px auto;
			width: 240px;
			height: 240px;
			border-radius: 50%;
			background: radial-gradient(circle, rgba(255, 255, 255, 0.34) 0%, rgba(255, 255, 255, 0) 72%);
		}

		.home-page .home-hero-card .card-body {
			position: relative;
			z-index: 1;
		}

		.home-page .home-hero-card .badge {
			background: rgba(255, 255, 255, 0.16) !important;
			color: #ffffff !important;
			border: 1px solid rgba(255, 255, 255, 0.35);
			backdrop-filter: blur(3px);
		}

		.home-page .home-hero-section .btn-outline-white {
			background: rgba(255, 255, 255, 0.16);
			border-color: rgba(255, 255, 255, 0.85);
			color: #ffffff;
		}

		.home-page .home-hero-section .btn-outline-white:hover {
			background: #ffffff;
			color: var(--ep-primary);
			border-color: #ffffff;
		}

		.home-page .home-stats-section .col-sm-6 > div {
			background: var(--ep-surface) !important;
			border: 1px solid var(--ep-line);
			border-radius: 1rem !important;
			box-shadow: 0 0.9rem 1.8rem rgba(14, 44, 80, 0.08);
			transition: transform 0.28s ease, box-shadow 0.28s ease, border-color 0.28s ease;
		}

		.home-page .home-stats-section .col-sm-6 > div:hover {
			transform: translateY(-5px);
			border-color: rgba(6, 106, 201, 0.24);
			box-shadow: 0 1.35rem 2.35rem rgba(14, 44, 80, 0.14);
		}

		.home-page .home-stats-section .display-6 {
			width: 58px;
			height: 58px;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			border-radius: 14px;
		}

		.home-page .home-stats-section .bg-warning.bg-opacity-15 .display-6 {
			background: var(--ep-warning-soft);
		}

		.home-page .home-stats-section .bg-purple.bg-opacity-10 .display-6 {
			background: rgba(147, 51, 234, 0.1);
		}

		.home-page .home-stats-section .bg-info.bg-opacity-10 .display-6 {
			background: rgba(13, 202, 240, 0.1);
		}

		.home-page .home-stats-section .bg-success.bg-opacity-10 .display-6 {
			background: rgba(25, 135, 84, 0.1);
		}

		.home-page .home-cta-card {
			border: 0;
			border-radius: 1.25rem !important;
			background:
				linear-gradient(135deg, #0d6efd 0%, #0aa8d2 52%, #3db96f 100%),
				url('{{ asset('assets/images/pattern/05.png') }}') center center / cover no-repeat;
			box-shadow: 0 1.55rem 3.2rem rgba(10, 45, 83, 0.3);
		}

		.home-page .home-cta-card .btn-warning {
			background: linear-gradient(135deg, #ffd45d 0%, #ffb72b 100%);
			border: 0;
			color: #6b3b00;
			box-shadow: 0 0.85rem 1.45rem rgba(255, 173, 35, 0.34);
		}

		.home-page .home-cta-card .btn-warning:hover {
			background: linear-gradient(135deg, #ffc94c 0%, #f39d14 100%);
			transform: translateY(-1px);
		}

		@keyframes homeFadeUp {
			from {
				opacity: 0;
				transform: translateY(18px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.home-page .home-hero-section .col-12,
		.home-page .home-stats-section .col-sm-6,
		.home-page .home-cta-section .col-12 {
			animation: homeFadeUp 0.65s ease both;
		}

		.home-page .home-stats-section .col-sm-6:nth-child(2) {
			animation-delay: 0.08s;
		}

		.home-page .home-stats-section .col-sm-6:nth-child(3) {
			animation-delay: 0.16s;
		}

		.home-page .home-stats-section .col-sm-6:nth-child(4) {
			animation-delay: 0.24s;
		}

		@media (max-width: 991.98px) {
			.home-page .home-hero-card,
			.home-page .home-cta-card {
				border-radius: 1rem !important;
			}

			.home-page .home-hero-section::before {
				width: 240px;
				height: 240px;
				top: -120px;
				right: -120px;
			}
		}
	</style>
<div class="home-page">
<!-- =======================
Main Banner START -->
<section class="home-hero-section pt-0">
		<div class="container">
			<div class="row">
				<div class="col-12">
					<!-- Card START -->
					<div class="card bg-dark rounded-3 p-4 p-sm-5 mt-4 home-hero-card">
						<div class="card-body">
							<div class="row align-items-center">
							<!-- Left content START -->
							<div class="col-lg-7">
								<!-- Badge -->
								<span class="badge bg-primary bg-opacity-10 text-primary mb-3"><i class="bi bi-calendar-event me-2"></i>Events Platform</span>
								<!-- Title -->
								<h1 class="text-white display-5 mb-3">Discover Our <span class="text-warning">Platform</span></h1>
								<p class="text-white">Explore our all-in-one platform for events, courses, quizzes, and e-commerce, designed to support every learner and family.</p>
								<!-- Button -->
								<div class="d-sm-flex align-items-center mt-4">
									<a href="#" class="btn btn-outline-white mb-0">Learn More</a>
								</div>
							</div>
							<!-- Left content END -->

							<!-- Right content START -->
							<div class="col-lg-5 text-center mt-4 mt-lg-0">
								<img src="{{ asset('assets/images/element/14.svg') }}" class="h-300px" alt="">
							</div>
							<!-- Right content END -->
						</div>
					</div>
				</div>
				<!-- Card END -->
			</div>
		</div>
	</div>
</section>
<!-- =======================
Main Banner END -->

<!-- =======================
Counter boxes START -->
<section class="home-stats-section pt-0 pt-md-5">
		<div class="container">
			<div class="row g-4">
			<!-- Counter item -->
			<div class="col-sm-6 col-xl-3">
				<div class="d-flex justify-content-center align-items-center p-4 bg-warning bg-opacity-15 rounded-3">
					<span class="display-6 lh-1 text-warning mb-0"><i class="bi bi-calendar-event"></i></span>
					<div class="ms-4">
						<div class="d-flex">
							<h5 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="150">0</h5>
							<span class="mb-0 h5">+</span>
						</div>
						<p class="mb-0 h6 fw-light">Total Events</p>
					</div>
				</div>
			</div>

			<!-- Counter item -->
			<div class="col-sm-6 col-xl-3">
				<div class="d-flex justify-content-center align-items-center p-4 bg-purple bg-opacity-10 rounded-3">
					<span class="display-6 lh-1 text-purple mb-0"><i class="fas fa-users"></i></span>
					<div class="ms-4">
						<div class="d-flex">
							<h5 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="5000">0</h5>
							<span class="mb-0 h5">+</span>
						</div>
						<p class="mb-0 h6 fw-light">Participants</p>
					</div>
				</div>
			</div>

			<!-- Counter item -->
			<div class="col-sm-6 col-xl-3">
				<div class="d-flex justify-content-center align-items-center p-4 bg-info bg-opacity-10 rounded-3">
					<span class="display-6 lh-1 text-info mb-0"><i class="bi bi-geo-alt"></i></span>
					<div class="ms-4">
						<div class="d-flex">
							<h5 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="25">0</h5>
							<span class="mb-0 h5">+</span>
						</div>
						<p class="mb-0 h6 fw-light">Locations</p>
					</div>
				</div>
			</div>

			<!-- Counter item -->
			<div class="col-sm-6 col-xl-3">
				<div class="d-flex justify-content-center align-items-center p-4 bg-success bg-opacity-10 rounded-3">
					<span class="display-6 lh-1 text-success mb-0"><i class="bi bi-trophy"></i></span>
					<div class="ms-4">
						<div class="d-flex">
							<h5 class="purecounter mb-0 fw-bold" data-purecounter-start="0" data-purecounter-end="100">0</h5>
							<span class="mb-0 h5">%</span>
						</div>
						<p class="mb-0 h6 fw-light">Satisfaction</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
<!-- =======================
Counter boxes END -->

	<!-- =======================
	CTA START -->
<section class="home-cta-section pt-0 pt-md-5">
		<div class="container">
			<div class="row">
				<div class="col-12">
					<div class="card bg-primary rounded-3 p-4 p-sm-5 home-cta-card">
						<div class="card-body">
							<div class="row align-items-center">
							<div class="col-lg-8">
								<h3 class="text-white mb-2">Ready to host your own event?</h3>
								<p class="text-white mb-0">Join our platform and start organizing amazing events today!</p>
							</div>
							<div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
								<a href="{{ path('app_admin_page') }}" class="btn btn-warning mb-0">Get Started<i class="bi bi-arrow-right ms-2"></i></a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
<!-- =======================
CTA END -->
</div>
{% endblock %}
